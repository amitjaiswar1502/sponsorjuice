---
import type { Platform } from '../../lib/types';
import seoConfig from '../../data/SEOConfig.json';
import Layout from '../../layouts/Layout.astro';
import CalculatorIsland from '../../components/calculator/CalculatorIsland';

export function getStaticPaths() {
  const platforms: Platform[] = ['tiktok', 'instagram', 'youtube'];
  return platforms.map((platform) => ({
    params: { platform },
    props: { platform, seo: seoConfig[platform] },
  }));
}

interface Props {
  platform: Platform;
  seo: (typeof seoConfig)[Platform];
}

const { platform, seo } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: seo.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Layout title={seo.title} description={seo.description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="bg-gradient-to-b from-juice-50 to-gray-50 py-12">
    <div class="mx-auto max-w-6xl px-4">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl md:text-5xl">
        {seo.h1}
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-gray-600">
        {seo.intro}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <CalculatorIsland client:visible initialPlatform={platform} />
  </section>

  <section class="border-t border-gray-200 bg-gray-50 py-12">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="mb-4 text-2xl font-bold text-gray-900">How to Use This Calculator</h2>
      <p class="text-gray-600">
        Start by setting average views per post and selecting a content niche. Add the
        primary audience location — creators with US and Canadian audiences typically command
        higher sponsorship rates. Then build a deliverables package by adding items like dedicated
        videos, integrated mentions, Stories, and bio link placements. The calculator shows a
        low-to-high rate range for confident negotiation. Save calculations for later
        or copy the auto-generated pitch email to send directly to brands.
      </p>
      <p class="mt-4 text-gray-600">
        Read the <a href="/blog/how-to-pitch/" class="font-medium text-juice-600 hover:text-juice-700">brand pitch guide{" "}</a>
        for outreach tips, or explore calculators for{" "}
        <a href="/calculator/tiktok/" class="text-juice-600 hover:text-juice-700">TikTok</a>,
        <a href="/calculator/instagram/" class="text-juice-600 hover:text-juice-700">Instagram</a>, and
        <a href="/calculator/youtube/" class="text-juice-600 hover:text-juice-700">YouTube</a>.
      </p>
    </div>
  </section>

  <section class="border-t border-gray-200 bg-white py-12">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="mb-6 text-2xl font-bold text-gray-900">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {
          seo.faqs.map((faq) => (
            <div>
              <h3 class="text-lg font-semibold text-gray-900">{faq.question}</h3>
              <p class="mt-2 text-gray-600">{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
