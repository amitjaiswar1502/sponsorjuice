---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/pages/PageHero.astro';
import PolicyToc from '../components/pages/PolicyToc.astro';
import ContentSection from '../components/pages/ContentSection.astro';

const sections = [
  { id: 'overview', label: 'Agreement to Terms' },
  { id: 'nature-of-service', label: 'Nature of Service & Rate Estimates' },
  { id: 'intellectual-property', label: 'Intellectual Property & Content' },
  { id: 'acceptable-use', label: 'Acceptable Use' },
  { id: 'third-party-links', label: 'Third-Party Services & Links' },
  { id: 'disclaimer-warranties', label: 'Disclaimer of Warranties' },
  { id: 'limitation-liability', label: 'Limitation of Liability' },
  { id: 'modifications', label: 'Modifications to Terms' },
  { id: 'contact', label: 'Contact Us' },
];
---

<Layout
  title="Terms of Service & Usage Agreement | SponsorJuice"
  description="Terms of Service for SponsorJuice creator rate calculator. Learn about our rate estimates disclaimer, user agreements, and acceptable use policy."
>
  <PageHero
    title="Terms of Service"
    subtitle="Please read these terms carefully before using SponsorJuice."
    badge="Last updated: July 23, 2026"
    currentPage="Terms"
  />

  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-12">
    <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-10">
      <PolicyToc sections={sections} />

      <div class="space-y-6">
        <ContentSection title="Agreement to Terms" id="overview">
          <p>
            By accessing or using SponsorJuice ("we," "us," or "our"), available at sponsorjuice.com, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website or services.
          </p>
        </ContentSection>

        <ContentSection title="Nature of Service & Rate Estimates Disclaimer" id="nature-of-service">
          <p>
            SponsorJuice provides a free online calculator and pitch builder designed to assist content creators in estimating brand deal and sponsorship rates for platforms like TikTok, Instagram, YouTube, and Facebook.
          </p>
          <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-5 text-amber-900">
            <h3 class="font-semibold text-amber-950">Financial & Pricing Disclaimer</h3>
            <p class="mt-2 text-sm leading-relaxed">
              All rate calculations, CPM multipliers, and deliverable packages generated by SponsorJuice are non-binding estimates based on publicly available market research and industry benchmarks. They do not constitute financial, legal, or professional business advice. Actual sponsorship values vary based on brand budgets, campaign objectives, creator negotiations, exclusivity terms, usage rights, and seasonal ad spending. Always conduct independent research before finalizing sponsorship contracts.
            </p>
          </div>
        </ContentSection>

        <ContentSection title="Intellectual Property & Content Use" id="intellectual-property">
          <p>
            All content, calculations, formulas, layout design, branding, and text on SponsorJuice are owned by SponsorJuice and protected by applicable copyright, trademark, and intellectual property laws.
          </p>
          <p class="mt-3">
            You are granted a limited, non-exclusive, non-transferable license to use our calculators and pitch email templates for your personal or commercial creator business outreach. You may not scrape, reproduce, redistribute, or mirror our underlying code or content for competing web applications without prior written permission.
          </p>
        </ContentSection>

        <ContentSection title="Acceptable Use" id="acceptable-use">
          <p>You agree to use SponsorJuice only for lawful purposes. You agree not to:</p>
          <ul class="mt-3 space-y-2 text-gray-700">
            <li>• Use automated tools, bots, or scrapers to access or overload our website infrastructure.</li>
            <li>• Attempt to bypass or modify any local storage calculation scripts or security measures.</li>
            <li>• Misrepresent rate estimates generated by SponsorJuice as official platform-sanctioned rates or guaranteed earnings.</li>
            <li>• Use our contact channels or forms to transmit spam, promotional materials, or malicious software.</li>
          </ul>
        </ContentSection>

        <ContentSection title="Third-Party Services & Advertising" id="third-party-links">
          <p>
            SponsorJuice displays advertisements served by third-party ad networks, including Google AdSense. We may also include links to third-party resources, articles, or platforms. We do not endorse, control, or assume responsibility for the content, privacy policies, or practices of any third-party websites or services.
          </p>
        </ContentSection>

        <ContentSection title="Disclaimer of Warranties" id="disclaimer-warranties">
          <p>
            SponsorJuice is provided on an "AS IS" and "AS AVAILABLE" basis without warranties of any kind, whether express or implied, including but not limited to implied warranties of merchantability, fitness for a particular purpose, or non-infringement. We do not warrant that our website will be uninterrupted, error-free, or free of viruses.
          </p>
        </ContentSection>

        <ContentSection title="Limitation of Liability" id="limitation-liability">
          <p>
            To the maximum extent permitted by applicable law, SponsorJuice and its operators shall not be liable for any direct, indirect, incidental, consequential, or punitive damages arising out of your access to, use of, or inability to use our site or any rate estimates provided herein.
          </p>
        </ContentSection>

        <ContentSection title="Modifications to Terms" id="modifications">
          <p>
            We reserve the right to revise these Terms of Service at any time. Updated terms will be posted on this page with a revised "Last updated" date. Your continued use of the website after changes are posted constitutes acceptance of the modified terms.
          </p>
        </ContentSection>

        <div id="contact" class="scroll-mt-24 rounded-2xl border border-juice-200 bg-gradient-to-br from-juice-50 to-white p-6 sm:p-8">
          <h2 class="text-xl font-bold text-gray-900">Questions about our Terms?</h2>
          <p class="mt-3 max-w-[65ch] text-base leading-[1.65] text-pretty text-gray-700">
            Email us at
            <a href="mailto:amitjaiswar1502@gmail.com" class="font-medium text-juice-600 hover:text-juice-700"> amitjaiswar1502@gmail.com </a>
            or visit our
            <a href="/contact/" class="font-medium text-juice-600 hover:text-juice-700"> contact page</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
