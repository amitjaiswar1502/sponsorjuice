---
import BreadcrumbSchema from '../seo/BreadcrumbSchema.astro';

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  currentPage: string;
}

const { title, subtitle, badge, currentPage } = Astro.props;

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: currentPage, url: Astro.url.pathname },
];
---

<BreadcrumbSchema items={breadcrumbItems} />

<section class="page-grain border-b border-juice-100 bg-gradient-to-br from-juice-50 via-white to-gray-50 py-10 md:py-14">
  <div class="relative mx-auto max-w-4xl px-4 sm:px-6">
    <nav aria-label="Breadcrumb" class="mb-4 text-sm text-gray-500">
      <ol class="flex flex-wrap items-center gap-1.5">
        <li>
          <a
            href="/"
            class="transition-colors duration-200 hover:text-juice-600 focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-juice-500"
          >
            Home
          </a>
        </li>
        <li aria-hidden="true" class="text-gray-500">/</li>
        <li class="font-medium text-gray-900" aria-current="page">{currentPage}</li>
      </ol>
    </nav>

    {
      badge && (
        <span class="mb-3 inline-block rounded-full bg-juice-100 px-3 py-1 text-xs font-medium tracking-wide text-juice-800 uppercase">
          {badge}
        </span>
      )
    }

    <h1 class="text-3xl font-bold tracking-tight text-balance text-gray-900 sm:text-4xl md:text-5xl">
      {title}
    </h1>

    {
      subtitle && (
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-gray-600">{subtitle}</p>
      )
    }
  </div>
</section>
