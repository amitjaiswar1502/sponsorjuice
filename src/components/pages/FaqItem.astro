---
interface Props {
  question: string;
}

const { question } = Astro.props;
---

<div class="rounded-xl border border-gray-100 border-l-4 border-l-juice-500 bg-white p-5 sm:p-6">
  <h3 class="text-base font-semibold text-gray-900">{question}</h3>
  <div class="mt-2 text-base leading-[1.65] text-gray-700">
    <slot />
  </div>
</div>
