---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/pages/PageHero.astro';
import ContentSection from '../components/pages/ContentSection.astro';

const features = [
  'Platform-specific rate calculators for TikTok, Instagram, YouTube, and Facebook',
  'A deliverables basket to build custom sponsorship packages',
  'Real-time outreach pitch templates you can copy and send',
  'Local calculation history stored in your browser',
  'Creator guides on pricing, pitching, and negotiating brand deals',
];
---

<Layout
  title="About SponsorJuice | Free Creator Rate Calculator"
  description="SponsorJuice helps content creators price brand deals on TikTok, Instagram, and YouTube with a free calculator, pitch templates, and creator guides."
>
  <PageHero
    title="About SponsorJuice"
    subtitle="We built SponsorJuice because creators deserve to know what to charge before they pitch a brand."
    currentPage="About"
  />

  <div class="mx-auto max-w-4xl space-y-8 px-4 py-10 sm:px-6 sm:py-12">
    <!-- Mission zig-zag -->
    <div class="grid gap-6 md:grid-cols-2 md:items-start md:gap-8">
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm sm:p-8">
        <h2 class="text-xl font-bold tracking-tight text-gray-900 sm:text-2xl">Our mission</h2>
        <p class="mt-4 max-w-[65ch] text-base leading-[1.65] text-pretty text-gray-700">
          SponsorJuice is a free tool for content creators who want fair compensation for sponsored
          content. Whether you create on TikTok, Instagram, or YouTube, our calculator estimates
          brand deal rates based on your actual reach — views, niche, audience location, and
          deliverables — not guesswork.
        </p>
      </div>
      <div class="rounded-2xl border border-juice-200 bg-gradient-to-br from-juice-50 to-white p-6 sm:p-8">
        <p class="text-sm font-medium tracking-wide text-juice-700 uppercase">At a glance</p>
        <ul class="font-data mt-4 space-y-3">
          <li class="flex items-baseline justify-between border-b border-juice-100 pb-3">
            <span class="text-gray-600">Platforms</span>
            <span class="text-2xl font-bold text-gray-900">3</span>
          </li>
          <li class="flex items-baseline justify-between border-b border-juice-100 pb-3">
            <span class="text-gray-600">Niche multipliers</span>
            <span class="text-2xl font-bold text-gray-900">4</span>
          </li>
          <li class="flex items-baseline justify-between">
            <span class="text-gray-600">Cost to use</span>
            <span class="text-2xl font-bold text-juice-600">Free</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Feature rows -->
    <section>
      <h2 class="mb-4 text-xl font-bold text-gray-900 sm:text-2xl">What we offer</h2>
      <ul class="divide-y divide-gray-100 overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
        {
          features.map((feature) => (
            <li class="flex items-start gap-3 px-5 py-4 sm:px-6 sm:py-5">
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-juice-500" aria-hidden="true" />
              <span class="text-base leading-[1.65] text-gray-700">{feature}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <ContentSection title="Who we serve">
      <p>
        SponsorJuice is designed for micro and mid-tier creators — typically between 5,000 and
        500,000 followers — who are landing their first brand deals or leveling up their sponsorship
        pricing. Our formulas reflect industry benchmarks while letting you adjust for your unique
        metrics. We update coefficients periodically based on published creator economy research.
      </p>
    </ContentSection>

    <ContentSection title="Our approach to pricing & data methodology">
      <p>
        We studied publicly available sponsorship benchmarks from influencer marketing platforms,
        creator economy reports, and agency rate cards to build our formula. The calculator uses
        average views as the primary input because that metric best reflects the actual reach a
        brand receives from your content. Niche and geography multipliers adjust for market demand
        — finance and tech audiences typically convert better for B2B brands, while US and Canadian
        audiences command premium CPMs compared to global averages.
      </p>
    </ContentSection>

    <ContentSection title="Editorial policy & standards">
      <p>
        At SponsorJuice, our guides, rate benchmarks, and pricing formulas are independently researched and written for content creators. We maintain strict editorial guidelines:
      </p>
      <ul class="mt-3 space-y-2 text-gray-700">
        <li><strong>Independent benchmarks:</strong> We do not accept payment from brands or agencies to inflate or deflate specific platform CPM rates.</li>
        <li><strong>Regular updates:</strong> Platform coefficients and niche multipliers are reviewed quarterly to reflect shifts in creator economy ad spending.</li>
        <li><strong>Transparent formulas:</strong> Our math is open and transparent so creators understand why a rate range is suggested.</li>
      </ul>
    </ContentSection>

    <!-- Disclaimer callout -->
    <div class="rounded-2xl border border-amber-200 bg-amber-50 p-6 sm:p-8">
      <h2 class="text-lg font-semibold text-amber-900">Important disclaimer</h2>
      <p class="mt-3 max-w-[65ch] text-base leading-[1.65] text-pretty text-amber-900">
        All rates shown on SponsorJuice are estimates based on publicly available industry data.
        They are not financial advice. Final sponsorship pricing depends on brand budget, campaign
        scope, exclusivity, usage rights, and negotiation. Always do your own research before
        accepting or declining a deal.
      </p>
    </div>

    <!-- CTA strip -->
    <div class="flex flex-col gap-3 rounded-2xl border border-gray-100 bg-white p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
      <div>
        <p class="font-semibold text-gray-900">Ready to price your next deal?</p>
        <p class="mt-1 text-sm text-gray-600">Use the calculator or get in touch with questions.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="/calculator/tiktok/"
          class="rounded-lg bg-juice-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors duration-200 hover:bg-juice-700 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-juice-500"
        >
          Open calculator
        </a>
        <a
          href="/contact/"
          class="rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-semibold text-gray-700 transition-colors duration-200 hover:border-juice-300 hover:bg-juice-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-juice-500"
        >
          Contact us
        </a>
      </div>
    </div>
  </div>
</Layout>
