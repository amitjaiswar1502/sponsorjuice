---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/pages/PageHero.astro';
import PolicyToc from '../components/pages/PolicyToc.astro';
import ContentSection from '../components/pages/ContentSection.astro';

const sections = [
  { id: 'overview', label: 'Overview' },
  { id: 'information', label: 'Information we collect' },
  { id: 'third-party', label: 'Third-party services' },
  { id: 'cookies', label: 'Cookies' },
  { id: 'retention', label: 'Data retention' },
  { id: 'children', label: "Children's privacy" },
  { id: 'rights', label: 'Your rights' },
  { id: 'changes', label: 'Policy changes' },
  { id: 'contact', label: 'Contact' },
];
---

<Layout
  title="Privacy Policy & Data Practices | SponsorJuice"
  description="SponsorJuice privacy policy explaining how we handle data, local storage, cookies, and third-party services like Google AdSense on our creator calculator."
>
  <PageHero
    title="Privacy policy"
    subtitle="How we handle your data when you use SponsorJuice."
    badge="Last updated: June 29, 2026"
    currentPage="Privacy"
  />

  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-12">
    <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-10">
      <PolicyToc sections={sections} />

      <div class="space-y-6">
        <ContentSection title="Overview" id="overview">
          <p>
            SponsorJuice ("we," "us," or "our") operates sponsorjuice.com, a free creator rate
            calculator. This policy explains what information we collect, how we use it, and your
            choices.
          </p>
        </ContentSection>

        <ContentSection title="Information we collect" id="information">
          <div class="space-y-6">
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-5">
              <h3 class="font-semibold text-gray-900">Local storage</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray-600">
                When you save a calculation, data is stored in your browser's localStorage on your
                device. We do not transmit saved calculations to our servers. You can clear this
                data at any time through your browser settings.
              </p>
            </div>
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-5">
              <h3 class="font-semibold text-gray-900">Analytics and advertising</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray-600">
                We may use Google AdSense to display advertisements. Google and its partners may use
                cookies to serve ads based on your prior visits. See{" "}
                <a href="https://policies.google.com/privacy">{" "}Google's Privacy Policy</a> for details.
              </p>
            </div>
          </div>
        </ContentSection>

        <ContentSection title="Third-party services & sub-processors" id="third-party">
          <p>
            SponsorJuice uses sub-processors to operate the website. A sub-processor is a
            third-party service provider that processes data on our behalf under a data processing
            agreement (DPA):
          </p>
          <ul class="mt-4 space-y-2">
            <li>
              <strong>Google AdSense</strong> — ad serving and measurement (Google LLC, United States)
            </li>
            <li>
              <strong>Hosting provider</strong> — serves static site files and may log IP addresses
            </li>
          </ul>
          <p class="mt-4">
            Google Analytics may be added in the future for site usage statistics. These providers
            act as sub-processors under their own privacy policies. We do not share personal
            calculation data with any third party because that data never leaves your browser.
          </p>
        </ContentSection>

        <ContentSection title="Cookies" id="cookies">
          <p>
            SponsorJuice itself does not set tracking cookies. Third-party ad providers may set
            cookies when ads are displayed. You can opt out of personalized advertising through
            <a href="https://www.google.com/settings/ads">{" "}Google Ad Settings</a>.
          </p>
        </ContentSection>

        <ContentSection title="Data retention" id="retention">
          <p>
            Calculation history stored in localStorage persists until you clear it or uninstall your
            browser data. We do not retain copies on our servers.
          </p>
        </ContentSection>

        <ContentSection title="Children's privacy" id="children">
          <p>
            SponsorJuice is not directed at children under 13. We do not knowingly collect personal
            information from children.
          </p>
        </ContentSection>

        <ContentSection title="Your rights" id="rights">
          <p>
            Because SponsorJuice does not collect personal data on our servers, there is no account
            data to access, modify, or delete from our side. You control all saved calculations
            through your browser's local storage settings. If we add analytics or account features
            in the future, this policy will be updated with corresponding data rights.
          </p>
        </ContentSection>

        <ContentSection title="Changes to this policy" id="changes">
          <p>
            We may update this policy from time to time. Changes will be posted on this page with an
            updated date.
          </p>
        </ContentSection>

        <div id="contact" class="scroll-mt-24 rounded-2xl border border-juice-200 bg-gradient-to-br from-juice-50 to-white p-6 sm:p-8">
          <h2 class="text-xl font-bold text-gray-900">Questions about this policy?</h2>
          <p class="mt-3 text-sm leading-relaxed text-gray-600 sm:text-base">
            Email us at
            <a href="mailto:hello@sponsorjuice.com" class="font-medium text-juice-600 hover:text-juice-700">{" "}hello@sponsorjuice.com{" "}</a>
            or visit our
            <a href="/contact" class="font-medium text-juice-600 hover:text-juice-700">{" "}contact page</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
