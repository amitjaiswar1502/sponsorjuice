---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
  title="Creator Guides & Brand Deal Tips | SponsorJuice Blog"
  description="Expert guides for creators on pricing brand deals, writing sponsorship pitches, and negotiating rates on TikTok, Instagram, and YouTube."
>
  <section class="bg-gradient-to-b from-juice-50 to-gray-50 py-10 sm:py-12">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Creator guides</h1>
      <p class="mt-4 text-lg text-gray-600">
        Practical advice on pricing, pitching, and landing brand deals. Use our{" "}
        <a href="/calculator/tiktok" class="font-medium text-juice-600 hover:text-juice-700">
          free rate calculator{" "}
        </a>
        alongside these guides to price with confidence.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <div class="prose max-w-prose text-gray-600">
      <p>
        Whether you are negotiating your first brand deal or re-pricing after a growth spurt, these
        guides cover the fundamentals: how to calculate fair rates, structure outreach emails,
        bundle deliverables into packages, and avoid common pricing mistakes. Pair each guide with
        our platform-specific calculators for TikTok, Instagram, and YouTube to turn advice into
        actionable numbers before you send a pitch.
      </p>
      <h2 class="mt-8 text-xl font-semibold text-gray-900">Topics We Cover</h2>
      <ul class="mt-4 list-disc space-y-2 pl-6">
        <li>How to calculate fair sponsorship rates by platform and niche</li>
        <li>Writing outreach emails that brands actually respond to</li>
        <li>Building deliverable packages instead of single-post pricing</li>
        <li>Negotiation tactics for micro and mid-tier creators</li>
        <li>FTC disclosure requirements for sponsored content</li>
      </ul>
      <p class="mt-6">
        The creator economy continues to grow, with brands allocating larger portions of marketing
        budgets to influencer partnerships each year. Whether you are a full-time creator or
        monetizing a side channel, understanding your market value is the first step toward
        sustainable income from brand deals. Our guides distill lessons from thousands of creator
        negotiations into practical advice you can apply today — no agency retainer required.
      </p>
      <p class="mt-4">
        Start with our featured guide on{" "}
        <a href="/blog/how-to-pitch" class="font-medium text-juice-600 hover:text-juice-700">
          how to pitch brands
        </a>, then use the{" "}
        <a href="/calculator/tiktok" class="font-medium text-juice-600 hover:text-juice-700">
          TikTok
        </a>{" "},
        <a href="/calculator/instagram" class="font-medium text-juice-600 hover:text-juice-700">
          Instagram{" "}
        </a>, or
        <a href="/calculator/youtube" class="font-medium text-juice-600 hover:text-juice-700">
          YouTube{" "}
        </a>
        calculator to set your rate before you send.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 pb-12 sm:px-6">
    <h2 class="mb-4 text-lg font-semibold text-gray-900 sm:mb-6 sm:text-xl">All posts</h2>
    <div class="space-y-4 sm:space-y-6">
      {
        posts.map((post) => (
          <article class="rounded-xl border border-gray-200 bg-white p-4 transition-shadow duration-200 hover:shadow-md sm:p-6">
            <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <h3 class="mt-2 text-lg font-semibold text-gray-900 sm:text-xl">
              <a href={`/blog/${post.id}`} class="transition-colors duration-200 hover:text-juice-600 focus-visible:rounded focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-juice-500">
                {post.data.title}
              </a>
            </h3>
            <p class="mt-2 text-gray-600">{post.data.description}</p>
            <p class="mt-2 text-sm text-gray-500">By {post.data.author}</p>
            {
              post.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-full bg-juice-50 px-2.5 py-0.5 text-xs font-medium text-juice-700">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
          </article>
        ))
      }
    </div>
  </section>
</Layout>
