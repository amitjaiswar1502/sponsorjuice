---
import type { Platform } from '../../lib/types';
import seoConfig from '../../data/SEOConfig.json';
import Layout from '../../layouts/Layout.astro';
import CalculatorIsland from '../../components/calculator/CalculatorIsland';
import CalculatorStaticFallback from '../../components/calculator/CalculatorStaticFallback.astro';

export function getStaticPaths() {
  const platforms: Platform[] = ['tiktok', 'instagram', 'youtube'];
  return platforms.map((platform) => ({
    params: { platform },
    props: { platform, seo: seoConfig[platform] },
  }));
}

interface Props {
  platform: Platform;
  seo: (typeof seoConfig)[Platform];
}

const { platform, seo } = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.site?.href || 'https://sponsorjuice.com';

const pageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: seo.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    },
    {
      '@type': 'WebApplication',
      name: seo.h1,
      url: `${siteUrl}/calculator/${platform}/`,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Any',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      description: seo.description,
    },
  ],
};
---

<Layout title={seo.title} description={seo.description}>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <section class="bg-gradient-to-b from-juice-50 to-gray-50 py-12">
    <div class="mx-auto max-w-6xl px-4">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl md:text-5xl">
        {seo.h1}
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-gray-600">
        {seo.intro}
      </p>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-gray-600">
        {seo.citabilityBlock}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <CalculatorStaticFallback platform={platform} />
    <div class="min-h-[48rem]">
      <CalculatorIsland client:load initialPlatform={platform} />
    </div>
  </section>

  <section class="border-t border-gray-200 bg-gray-50 py-12">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="mb-4 text-2xl font-bold text-gray-900">{seo.howToUseHeading}</h2>
      <p class="text-gray-600">{seo.howToUse}</p>
      <p class="mt-4 text-gray-600">
        Read our{' '}
        <a href="/blog/how-to-pitch/" class="font-medium text-juice-600 hover:text-juice-700">brand pitch guide</a>{' '}
        {seo.crossLinkSuffix}
      </p>
    </div>
  </section>

  <section class="border-t border-gray-200 bg-white py-12">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="mb-6 text-2xl font-bold text-gray-900">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {
          seo.faqs.map((faq) => (
            <div>
              <h3 class="text-lg font-semibold text-gray-900">{faq.question}</h3>
              <p class="mt-2 text-gray-600">{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
