---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/pages/PageHero.astro';
import ContactCard from '../components/pages/ContactCard.astro';
import ContentSection from '../components/pages/ContentSection.astro';
import FaqItem from '../components/pages/FaqItem.astro';

const timeline = [
  { label: 'Standard inquiries', time: '2–3 business days' },
  { label: 'High-volume periods', time: 'Up to 5 business days' },
  { label: 'Urgent calculator bugs', time: 'Include browser + screenshot for faster help' },
];
---

<Layout
  title="Contact SponsorJuice | Creator Calculator Support"
  description="Get in touch with the SponsorJuice team for questions about our free creator rate calculator, brand deal pricing, or partnership inquiries."
>
  <PageHero
    title="Contact us"
    subtitle="Questions, feedback, or partnership inquiries — we'd love to hear from you."
    currentPage="Contact"
  />

  <div class="mx-auto max-w-4xl space-y-8 px-4 py-10 sm:px-6 sm:py-12">
    <div class="grid gap-4 sm:grid-cols-2 sm:gap-6">
      <ContactCard
        title="General inquiries"
        description="Questions about the calculator, rate estimates, or feature suggestions."
        email="amitjaiswar1502@gmail.com"
        responseTime="Response within 2–3 business days"
      />
      <ContactCard
        title="Press & partnerships"
        description="Media inquiries or partnership opportunities with your publication or organization."
        email="amitjaiswar1502@gmail.com"
        responseTime="Include details about your publication"
      />
    </div>

    <div class="rounded-2xl border border-gray-100 border-l-4 border-l-juice-500 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-bold text-gray-900">Creator support</h2>
      <p class="mt-3 max-w-[65ch] text-base leading-[1.65] text-pretty text-gray-700">
        Need help pricing a specific brand deal? Start with our{" "}
        <a href="/calculator/tiktok/" class="font-medium text-juice-600 hover:text-juice-700">rate calculator{" "}</a>
        and read our guide on
        <a href="/blog/how-to-pitch/" class="font-medium text-juice-600 hover:text-juice-700">{" "}how to pitch brands</a>.
        These resources cover the most common questions about sponsorship pricing and outreach.
      </p>
    </div>

    <section>
      <h2 class="mb-4 text-xl font-bold text-gray-900 sm:text-2xl">Frequently asked questions</h2>
      <div class="space-y-4">
        <FaqItem question="Can I suggest a feature or support other platforms?">
          Absolutely. We are planning to add calculations for Twitch, Pinterest, and newsletter sponsorship channels. Email
          <a href="mailto:amitjaiswar1502@gmail.com" class="font-medium text-juice-600 hover:text-juice-700">{" "}amitjaiswar1502@gmail.com{" "}</a>
          with your ideas, and we will consider them for future updates.
        </FaqItem>
        <FaqItem question="The calculator isn't working — what should I try?">
          Clear your browser cache or use a supported modern browser (Chrome, Firefox, Safari, or
          Edge). Most issues resolve with a hard refresh. If problems persist, email us with your
          browser name and a screenshot.
        </FaqItem>
      </div>
    </section>

    <ContentSection title="Response times">
      <ul class="space-y-0 divide-y divide-gray-100">
        {
          timeline.map((item) => (
            <li class="flex flex-col gap-1 py-4 first:pt-0 sm:flex-row sm:items-center sm:justify-between">
              <span class="font-medium text-gray-900">{item.label}</span>
              <span class="text-sm text-gray-600">{item.time}</span>
            </li>
          ))
        }
      </ul>
    </ContentSection>

    <p class="text-center text-sm text-gray-500">
      For data and privacy details, see our
      <a href="/privacy/" class="font-medium text-juice-600 hover:text-juice-700">{" "}privacy policy</a>.
    </p>
  </div>
</Layout>
