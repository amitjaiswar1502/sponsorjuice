---
import Layout from '../layouts/Layout.astro';
import CalculatorIsland from '../components/calculator/CalculatorIsland';
import CalculatorStaticFallback from '../components/calculator/CalculatorStaticFallback.astro';
import AdSenseContainer from '../components/AdSenseContainer.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.site?.href || 'https://sponsorjuice.com';
const adSlotId = import.meta.env.PUBLIC_ADSENSE_HOME_SLOT || '';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'SponsorJuice',
      url: siteUrl,
      description:
        'Free creator rate calculator for TikTok, Instagram, YouTube, and Facebook brand deals with pitch templates and local history.',
    },
    {
      '@type': 'WebApplication',
      name: 'SponsorJuice Creator Rate Calculator',
      url: siteUrl,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Any',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      description:
        'Free calculator for TikTok, Instagram, YouTube, and Facebook brand deal pricing with deliverables packages and pitch templates.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is SponsorJuice free to use?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes, SponsorJuice is 100% free. All calculations, package builders, and pitch templates are fully accessible without any paywalls or registration requirements.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does SponsorJuice store my personal data?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No, SponsorJuice runs entirely locally in your web browser. No follower metrics, view counts, or calculated rates are ever uploaded to any database or server. All history is stored purely in your browser\'s local storage.',
          },
        },
        {
          '@type': 'Question',
          name: 'How are creator rates determined?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Rates are estimated using standard industry CPM ranges. The formula multiplies average video/reel views by a platform coefficient, and scales the range using specific content niche and target audience geography factors.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does everything run in my browser?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. SponsorJuice runs entirely client-side in your browser. All calculations happen on your device without sending metrics to our servers. Saved history persists in local storage until you clear it.',
          },
        },
      ],
    },
  ],
};
---

<Layout
  title="SponsorJuice — Free Creator Rate Calculator & Brand Pitch Builder"
  description="Price TikTok, Instagram, YouTube, and Facebook brand deals with our free calculator. Build sponsorship packages, generate pitch emails, and save rates locally."
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <section class="bg-gradient-to-b from-juice-50 to-gray-50 py-16">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <h1 class="min-h-[5.5rem] text-4xl leading-tight font-bold tracking-tight text-gray-900 md:min-h-[6.5rem] md:text-5xl">
        Know Your Worth.<br />
        <span class="text-juice-600">Charge With Confidence.</span>
      </h1>
      <p class="mx-auto mt-4 max-w-[65ch] text-lg leading-[1.65] text-pretty text-gray-600">
        Free creator rate calculator for TikTok, Instagram, YouTube, and Facebook brand deals.
        Build packages, generate pitch emails, and save calculations locally.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/calculator/tiktok/"
          class="rounded-lg bg-juice-600 px-6 py-3 text-sm font-semibold text-white hover:bg-juice-700"
        >
          TikTok Calculator
        </a>
        <a
          href="/calculator/instagram/"
          class="rounded-lg border border-juice-300 bg-white px-6 py-3 text-sm font-semibold text-juice-700 hover:bg-juice-50"
        >
          Instagram Calculator
        </a>
        <a
          href="/calculator/youtube/"
          class="rounded-lg border border-juice-300 bg-white px-6 py-3 text-sm font-semibold text-juice-700 hover:bg-juice-50"
        >
          YouTube Calculator
        </a>
        <a
          href="/calculator/facebook/"
          class="rounded-lg border border-juice-300 bg-white px-6 py-3 text-sm font-semibold text-juice-700 hover:bg-juice-50"
        >
          Facebook Calculator
        </a>
      </div>
    </div>
  </section>

  <section class="border-b border-gray-200 bg-white py-10">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">What is SponsorJuice?</h2>
      <p class="mt-4 max-w-[65ch] text-base leading-[1.65] text-pretty text-gray-700">
        SponsorJuice is a free creator rate calculator. Enter your average views, niche, audience
        location, and deliverables — we estimate a fair sponsorship range and generate outreach copy.
        No account required; everything runs in your browser and saved quotes stay in local storage only.
      </p>

      <div class="mt-8">
        <h3 class="text-sm font-semibold tracking-wide text-gray-900">
          Platform coefficient <span class="font-normal text-gray-500">(per view, before niche &amp; geo)</span>
        </h3>
        <dl class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <div class="flex items-center justify-between gap-4 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
            <dt class="text-sm font-medium text-gray-700">TikTok</dt>
            <dd class="font-data text-sm font-semibold text-gray-900">$0.005–$0.012</dd>
          </div>
          <div class="flex items-center justify-between gap-4 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
            <dt class="text-sm font-medium text-gray-700">Instagram</dt>
            <dd class="font-data text-sm font-semibold text-gray-900">$0.007–$0.015</dd>
          </div>
          <div class="flex items-center justify-between gap-4 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
            <dt class="text-sm font-medium text-gray-700">YouTube</dt>
            <dd class="font-data text-sm font-semibold text-gray-900">$0.015–$0.035</dd>
          </div>
          <div class="flex items-center justify-between gap-4 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
            <dt class="text-sm font-medium text-gray-700">Facebook</dt>
            <dd class="font-data text-sm font-semibold text-gray-900">$0.005–$0.013</dd>
          </div>
        </dl>
      </div>

      <div class="mt-8 rounded-xl border border-juice-200 bg-juice-50/60 p-5">
        <p class="text-sm font-semibold text-gray-900">Example dedicated-video range</p>
        <p class="mt-1 text-sm text-gray-600">
          Beauty niche · <span class="font-data text-gray-800">10,000</span> avg views · US/Canada audience
        </p>
        <ul class="mt-4 space-y-2.5">
          <li class="flex items-center justify-between gap-4 border-b border-juice-200/80 pb-2.5 text-sm last:border-0 last:pb-0">
            <span class="font-medium text-gray-700">TikTok</span>
            <span class="font-data font-semibold text-juice-700">$90–$216</span>
          </li>
          <li class="flex items-center justify-between gap-4 border-b border-juice-200/80 pb-2.5 text-sm last:border-0 last:pb-0">
            <span class="font-medium text-gray-700">Instagram</span>
            <span class="font-data font-semibold text-juice-700">$126–$270</span>
          </li>
          <li class="flex items-center justify-between gap-4 border-b border-juice-200/80 pb-2.5 text-sm last:border-0 last:pb-0">
            <span class="font-medium text-gray-700">Facebook</span>
            <span class="font-data font-semibold text-juice-700">$90–$234</span>
          </li>
          <li class="flex items-center justify-between gap-4 text-sm">
            <span class="font-medium text-gray-700">YouTube</span>
            <span class="font-data font-semibold text-juice-700">$270–$630</span>
          </li>
        </ul>
      </div>

      <p class="mt-6 max-w-[65ch] text-base leading-[1.65] text-pretty text-gray-600">
        Estimates follow publicly cited influencer marketing CPM benchmarks. Niche and geography
        multipliers adjust each range — use the calculator above for your exact metrics.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <CalculatorStaticFallback />
    <div class="min-h-[48rem]">
      <CalculatorIsland client:load />
    </div>
  </section>

  <section class="border-t border-gray-200 bg-white py-12">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center text-2xl font-bold text-gray-900">
        How SponsorJuice Calculates Brand Deal Rates
      </h2>
      <p class="mx-auto mb-8 max-w-3xl text-center text-gray-600">
        Our formula multiplies average views by a platform coefficient, niche multiplier, and
        audience geography weight. Add deliverables like dedicated videos, Stories, and bio links
        to build a custom package rate. Every estimate is a range — because real deals depend on
        brand budget, exclusivity, and usage rights.
      </p>
      <p class="mx-auto mb-8 max-w-3xl text-center text-gray-600">
        SponsorJuice runs entirely in the browser — no account required, no metrics sent to external
        servers. Adjust the sliders, build a deliverables package, and copy a personalized pitch
        email in under two minutes. Saved calculations stay locally using local storage so
        creators can compare rates across platforms and campaigns over time.
      </p>
      <h2 class="mb-8 text-center text-2xl font-bold text-gray-900">
        Why Creators Use SponsorJuice
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-gray-200 p-6 text-center">
          <p class="text-3xl" aria-hidden="true">⚡</p>
          <h3 class="mt-3 font-semibold text-gray-900">Instant Results</h3>
          <p class="mt-2 text-base leading-[1.65] text-gray-700">
            Pure static HTML loads instantly. Calculator hydrates only when you need it.
          </p>
        </div>
        <div class="rounded-xl border border-gray-200 p-6 text-center">
          <p class="text-3xl" aria-hidden="true">📦</p>
          <h3 class="mt-3 font-semibold text-gray-900">Package Builder</h3>
          <p class="mt-2 text-base leading-[1.65] text-gray-700">
            Combine deliverables into custom packages with automatic rate multipliers.
          </p>
        </div>
        <div class="rounded-xl border border-gray-200 p-6 text-center">
          <p class="text-3xl" aria-hidden="true">✉️</p>
          <h3 class="mt-3 font-semibold text-gray-900">Pitch Generator</h3>
          <p class="mt-2 text-base leading-[1.65] text-gray-700">
            Real-time outreach templates that update as metrics are adjusted.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-gray-200 bg-gray-50 py-12">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="text-2xl font-bold text-gray-900">Latest Creator Guide</h2>
      <p class="mt-4 text-gray-600">
        New to brand outreach? Read our step-by-step guide on{' '}
        <a href="/blog/how-to-pitch/" class="font-medium text-juice-600 hover:text-juice-700">
          how to pitch brands as a content creator
        </a>{' '}
        — including email structure, package pricing, and common mistakes to avoid.
      </p>
    </div>
  </section>

  <section class="border-t border-gray-200 bg-white py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="mb-8 text-center text-3xl font-bold tracking-tight text-gray-900">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        <details class="group rounded-xl border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden transition-all duration-300 open:bg-juice-50/30 open:border-juice-200">
          <summary class="flex cursor-pointer items-center justify-between gap-1.5 text-gray-900">
            <h3 class="text-lg font-semibold">Is SponsorJuice free to use?</h3>
            <span class="relative h-5 w-5 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-100 group-open:opacity-0 transition-opacity duration-300 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-0 group-open:opacity-100 transition-opacity duration-300 text-juice-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 max-w-[65ch] leading-[1.65] text-gray-700">
            Yes, SponsorJuice is 100% free. All calculations, package builders, and pitch templates are fully accessible without any paywalls or registration requirements.
          </p>
        </details>

        <details class="group rounded-xl border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden transition-all duration-300 open:bg-juice-50/30 open:border-juice-200">
          <summary class="flex cursor-pointer items-center justify-between gap-1.5 text-gray-900">
            <h3 class="text-lg font-semibold">Does SponsorJuice store my personal data?</h3>
            <span class="relative h-5 w-5 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-100 group-open:opacity-0 transition-opacity duration-300 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-0 group-open:opacity-100 transition-opacity duration-300 text-juice-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 max-w-[65ch] leading-[1.65] text-gray-700">
            No, SponsorJuice runs entirely locally in your web browser. No follower metrics, view counts, or calculated rates are ever uploaded to any database or server. All history is stored purely in your browser's local storage.
          </p>
        </details>

        <details class="group rounded-xl border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden transition-all duration-300 open:bg-juice-50/30 open:border-juice-200">
          <summary class="flex cursor-pointer items-center justify-between gap-1.5 text-gray-900">
            <h3 class="text-lg font-semibold">How are creator rates determined?</h3>
            <span class="relative h-5 w-5 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-100 group-open:opacity-0 transition-opacity duration-300 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-0 group-open:opacity-100 transition-opacity duration-300 text-juice-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 max-w-[65ch] leading-[1.65] text-gray-700">
            Rates are estimated using standard industry CPM ranges. The formula multiplies average video/reel views by a platform coefficient, and scales the range using specific content niche and target audience geography factors.
          </p>
        </details>

        <details class="group rounded-xl border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden transition-all duration-300 open:bg-juice-50/30 open:border-juice-200">
          <summary class="flex cursor-pointer items-center justify-between gap-1.5 text-gray-900">
            <h3 class="text-lg font-semibold">Does everything run in my browser?</h3>
            <span class="relative h-5 w-5 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-100 group-open:opacity-0 transition-opacity duration-300 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-5 w-5 opacity-0 group-open:opacity-100 transition-opacity duration-300 text-juice-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 max-w-[65ch] leading-[1.65] text-gray-700">
            Yes. SponsorJuice runs entirely client-side in your browser. All calculations happen on your device without sending metrics to our servers. Saved history persists in local storage until you clear it.
          </p>
        </details>
      </div>
    </div>
  </section>

  {
    adSlotId && (
      <section class="mx-auto max-w-6xl px-4 py-8">
        <AdSenseContainer slotId={adSlotId} format="horizontal" />
      </section>
    )
  }
</Layout>
