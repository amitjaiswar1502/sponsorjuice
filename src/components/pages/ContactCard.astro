---
interface Props {
  title: string;
  description: string;
  email: string;
  responseTime: string;
}

const { title, description, email, responseTime } = Astro.props;
---

<a
  href={`mailto:${email}`}
  class="group flex flex-col rounded-2xl border border-gray-100 bg-white p-6 shadow-sm shadow-juice-100/40 transition-all duration-200 hover:-translate-y-0.5 hover:border-juice-200 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-juice-500 sm:p-8"
>
  <h3 class="text-lg font-semibold text-gray-900">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{description}</p>
  <p class="mt-4 font-medium text-juice-600 transition-colors group-hover:text-juice-700">
    {email}
  </p>
  <p class="mt-1 text-xs text-gray-500">{responseTime}</p>
</a>
