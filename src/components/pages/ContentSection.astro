---
interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<section {id && { id }} class="scroll-mt-24">
  <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm shadow-juice-100/50 sm:p-8">
    <h2 class="text-xl font-bold tracking-tight text-gray-900 sm:text-2xl">{title}</h2>
    <div class="prose mt-4 max-w-none">
      <slot />
    </div>
  </div>
</section>
